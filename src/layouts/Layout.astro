---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useStoryblokApi } from '@storyblok/astro';
const { title = 'CMN — Christians on Mission for Nations' } = Astro.props;
let settings = null;
try {
  const api = useStoryblokApi();
  const { data } = await api.get('cdn/stories/settings', { version: 'draft' });
  settings = data?.story?.content || null;
} catch (e) { settings = null; }
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      // Applique le thème AVANT le rendu (évite tout clignotement).
      (function () {
        try {
          var t = localStorage.getItem('cmn_theme');
          if (t !== 'dark' && t !== 'light') {
            t = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
          }
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header settings={settings} />
    <slot />
    <section class="nlband">
      <div class="wrap nlwrap">
        <div class="nltext">
          <strong>Restez informé de la mission</strong>
          <span>Nouvelles du terrain, prières exaucées et temps forts — directement dans votre boîte mail.</span>
        </div>
        <form class="nlform">
          <input type="email" placeholder="Votre adresse email" aria-label="Adresse email" required />
          <button class="btn btn-gold" type="submit">S'inscrire</button>
        </form>
      </div>
      <div class="wrap">
        <label class="nlconsent"><input type="checkbox" /> <span>J'accepte de recevoir la newsletter de CMN et je peux me désinscrire à tout moment (voir la politique de confidentialité).</span></label>
      </div>
    </section>
    <Footer settings={settings} />
    <script is:inline>
      (function () {
        var b = document.getElementById('themeBtn');
        function refresh() {
          var d = document.documentElement.getAttribute('data-theme') === 'dark';
          var ic = b && b.querySelector('.ti');
          if (ic) ic.textContent = d ? '☀️' : '🌙';
          if (b) b.setAttribute('aria-pressed', d ? 'true' : 'false');
        }
        refresh();
        if (b) b.addEventListener('click', function () {
          var d = document.documentElement.getAttribute('data-theme') === 'dark';
          var next = d ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('cmn_theme', next); } catch (e) {}
          refresh();
        });
      })();
    </script>
  </body>
</html>
