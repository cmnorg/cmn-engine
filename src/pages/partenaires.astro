---
import Layout from '../layouts/Layout.astro';
import { useStoryblokApi } from '@storyblok/astro';

function u(v) { if (!v) return ''; if (typeof v === 'string') return v; return v.filename || v.url || v.cached_url || ''; }

let settings = {};
try {
  const api = useStoryblokApi();
  const { data } = await api.get('cdn/stories/settings', { version: 'draft' });
  settings = (data && data.story && data.story.content) || {};
} catch (e) { settings = {}; }

// Les paliers renvoient vers la page Don (entonnoir), qui transmet ensuite à Stripe.
const donateUrl = '/faire-un-don';
const heroImg = u(settings.part_hero);
const partnerPhoto = u(settings.part_photo);

const tiers = [
  { key: 'ami', name: 'Ami', amount: 15, emoji: '🤝', img: u(settings.part_img_ami), impact: 'Tu soutiens la diffusion de l’Évangile en ligne.', concrete: '≈ 150 personnes touchées en ligne / mois' },
  { key: 'compagnon', name: 'Compagnon', amount: 30, emoji: '🌱', img: u(settings.part_img_compagnon), impact: 'Tu aides à former un disciple chaque mois.', concrete: '= 1 disciple formé chaque mois' },
  { key: 'batisseur', name: 'Bâtisseur', amount: 75, emoji: '🧱', img: u(settings.part_img_batisseur), impact: 'Tu soutiens une action humanitaire de terrain.', concrete: '= 1 famille aidée sur le terrain', popular: true },
  { key: 'pilier', name: 'Pilier', amount: 150, emoji: '🏛️', img: u(settings.part_img_pilier), impact: 'Tu portes une campagne d’évangélisation entière.', concrete: 'contribue à une croisade complète' },
];
---
<Layout title="CMN — Devenir partenaire">
  <section class="pt">
    <div class={`pt-hero${heroImg ? ' pt-hero--img' : ''}`} style={heroImg ? `background-image:linear-gradient(rgba(28,28,26,.72),rgba(28,28,26,.72)),url(${heroImg})` : ''}>
      <div class="wrap">
        <div class="disc-label">Partenaires</div>
        <h1>Deviens partenaire de la mission</h1>
        <p>Un partenaire mensuel se tient à nos côtés, mois après mois. Ton soutien régulier nous permet de planifier les campagnes, former des disciples et faire vivre les projets humanitaires dans la durée.</p>
        <div class="pt-trust">
          <span>🔒 Paiement sécurisé</span>
          <span>🧾 Reçu fiscal automatique</span>
          <span>✋ Résiliable à tout moment</span>
        </div>
      </div>
    </div>

    <div class="wrap">
      <!-- Sélecteur fréquence -->
      <div class="pt-freq" role="group" aria-label="Fréquence du don">
        <button class="pt-freq-btn active" data-freq="monthly" type="button">Mensuel <small>recommandé</small></button>
        <button class="pt-freq-btn" data-freq="once" type="button">Ponctuel</button>
      </div>

      <!-- Paliers (avec image éditable depuis Storyblok) -->
      <div class="pt-tiers">
        {tiers.map((t, i) => (
          <article class={`pt-tier accent-${i}${t.popular ? ' feat' : ''}`} data-amount={t.amount}>
            {t.popular && <div class="pt-ribbon">Le plus choisi</div>}
            <div class="pt-ph" style={t.img ? `background-image:url(${t.img})` : ''}></div>
            <div class="pt-bd">
              <span class="pt-icon">{t.emoji}</span>
              <div class="pt-badge">{t.name}</div>
              <div class="pt-amt"><strong>{t.amount} €</strong><span class="pt-per">/mois</span></div>
              <div class="pt-concrete">{t.concrete}</div>
              <p class="pt-impact">{t.impact}</p>
              <a class={`btn ${t.popular ? 'btn-gold' : 'btn-ghost'} pt-pick`} href={`${donateUrl}?amount=${t.amount}&freq=monthly`} data-amount={t.amount}>Devenir partenaire</a>
            </div>
          </article>
        ))}
      </div>

      <!-- Montant libre -->
      <div class="pt-custom">
        <span>Tu préfères choisir ton montant ?</span>
        <div class="pt-custom-row">
          <input type="number" id="ptAmt" min="1" step="1" placeholder="Montant" inputmode="numeric" />
          <span class="pt-cur">€</span>
          <a class="btn btn-gold" id="ptCustomBtn" href={`${donateUrl}?freq=monthly`}>Donner ce montant</a>
        </div>
        <span class="pt-amt-msg" id="ptAmtMsg"></span>
      </div>

      <!-- Preuve sociale -->
      <div class="pt-social">
        {partnerPhoto && <img class="pt-social-ph" src={partnerPhoto} alt="Partenaire CMN" />}
        <blockquote>« Être partenaire mensuel, c'est porter la mission dans la durée. On reçoit des nouvelles du terrain et on voit concrètement l'impact. »</blockquote>
        <cite>— Un partenaire CMN</cite>
      </div>

      <!-- Bénéfices -->
      <h2 class="pt-h2">Ce que vivent nos partenaires</h2>
      <div class="pt-benefits">
        <div class="pt-ben"><div class="pt-ben-ic">📨</div><h3>Nouvelles de la mission</h3><p>Reçois les rapports du terrain et les prières exaucées.</p></div>
        <div class="pt-ben"><div class="pt-ben-ic">🙏</div><h3>Prière</h3><p>Nous prions régulièrement pour nos partenaires.</p></div>
        <div class="pt-ben"><div class="pt-ben-ic">🧾</div><h3>Transparence</h3><p>Reçu fiscal et impact détaillé de tes dons. <a href="/faire-un-don">Voir où va ton don →</a></p></div>
      </div>

      <!-- Autres façons de soutenir -->
      <div class="pt-other">
        <div class="pt-other-card">
          <h3>🙏 Partenaire de prière</h3>
          <p>Pas (encore) en mesure de donner ? Deviens partenaire de prière : ton intercession est précieuse.</p>
          <a class="btn btn-ghost" href="/mur-de-priere">Rejoindre la prière</a>
        </div>
        <div class="pt-other-card">
          <h3>🤝 Partenariats & organisations</h3>
          <p>Église, entreprise ou ONG ? Construisons un partenariat stratégique.</p>
          <a class="btn btn-ghost" href="/contact?sujet=Partenariat">Nous contacter</a>
        </div>
      </div>

      <!-- Bandeau final -->
      <div class="pt-band">
        <h3>Tiens-toi à nos côtés, épaule contre épaule, pour transformer les nations.</h3>
        <a class="btn btn-gold pt-pick" href={`${donateUrl}?amount=75&freq=monthly`} data-amount="75">Devenir partenaire mensuel</a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ donateUrl }}>
    (function () {
      var freq = 'monthly';
      var freqBtns = document.querySelectorAll('.pt-freq-btn');
      var pers = document.querySelectorAll('.pt-per');
      var picks = document.querySelectorAll('.pt-pick');

      function syncFreq() {
        pers.forEach(function (p) { p.textContent = freq === 'monthly' ? '/mois' : ''; });
        picks.forEach(function (a) {
          var amt = a.getAttribute('data-amount');
          a.href = donateUrl + (amt ? ('?amount=' + amt + '&freq=' + freq) : ('?freq=' + freq));
        });
        var cb = document.getElementById('ptCustomBtn');
        var amt = (document.getElementById('ptAmt') || {}).value;
        if (cb) cb.href = donateUrl + (amt ? ('?amount=' + amt + '&freq=' + freq) : ('?freq=' + freq));
      }

      freqBtns.forEach(function (b) {
        b.addEventListener('click', function () {
          freqBtns.forEach(function (x) { x.classList.remove('active'); });
          b.classList.add('active');
          freq = b.getAttribute('data-freq');
          syncFreq();
        });
      });

      var amtEl = document.getElementById('ptAmt');
      var amtMsg = document.getElementById('ptAmtMsg');
      var customBtn = document.getElementById('ptCustomBtn');
      var MIN = 1; // montant minimum (modifiable)

      if (amtEl) amtEl.addEventListener('input', function () {
        amtEl.classList.remove('pt-amt-err');
        if (amtMsg) amtMsg.textContent = '';
        syncFreq();
      });

      if (customBtn) customBtn.addEventListener('click', function (e) {
        var val = parseInt((amtEl && amtEl.value) || '', 10);
        if (!(val >= MIN)) {
          e.preventDefault();
          if (amtEl) { amtEl.classList.add('pt-amt-err'); amtEl.focus(); }
          if (amtMsg) amtMsg.textContent = (amtEl && amtEl.value)
            ? ('Le montant minimum est de ' + MIN + ' €.')
            : 'Tu as oublié de saisir ton montant 🙂';
        }
      });

      syncFreq();
    })();
  </script>
</Layout>
