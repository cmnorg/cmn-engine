---
import Layout from '../layouts/Layout.astro';
import { useStoryblokApi } from '@storyblok/astro';

function u(v) { if (!v) return ''; if (typeof v === 'string') return v; return v.filename || v.url || v.cached_url || ''; }

let settings = {};
try {
  const api = useStoryblokApi();
  const { data } = await api.get('cdn/stories/settings', { version: 'draft' });
  settings = (data && data.story && data.story.content) || {};
} catch (e) { settings = {}; }

const socials = [
  { url: u(settings.youtube), label: 'YouTube' },
  { url: u(settings.facebook), label: 'Facebook' },
  { url: u(settings.instagram), label: 'Instagram' },
  { url: u(settings.tiktok), label: 'TikTok' },
  { url: u(settings.linkedin), label: 'LinkedIn' },
  { url: u(settings.whatsapp_channel), label: 'WhatsApp' },
].filter((s) => s.url);

const subjects = [
  'Question générale', 'Partenariat', 'Demande de prière',
  'Bénévolat / Mission', 'Proposer un groupe (Connect)', 'Presse & médias', 'Faire un don', 'Autre',
];
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || '0x4AAAAAADnaOySkkvvQhUrg';
---
<Layout title="CMN — Contact">
  <section class="ct">
    <div class="ct-hero">
      <div class="wrap">
        <div class="phead-label disc-label">Contact</div>
        <h1>Écris-nous</h1>
        <p>Une question, un projet de partenariat, une demande de prière ? Notre équipe te répond avec joie.</p>
      </div>
    </div>

    <div class="wrap">
      <div class="ct-cols">
        <!-- Coordonnées -->
        <aside class="ct-info">
          <h3>Restons en lien</h3>
          <p class="ct-info-lead">Nous lisons chaque message et répondons généralement sous 48 h.</p>

          <div class="ct-line ct-line--static">
            <span class="ct-ic">✉️</span>
            <span><strong>Écris-nous</strong><span>Remplis le formulaire, on te répond vite.</span></span>
          </div>

          {socials.length > 0 && (
            <div class="ct-soc">
              <strong>Suis-nous</strong>
              <div class="ct-soc-row">
                {socials.map((s) => <a href={s.url} target="_blank" rel="noopener">{s.label}</a>)}
              </div>
            </div>
          )}

          <div class="ct-quick">
            <strong>Accès rapides</strong>
            <a href="/faire-un-don">💛 Faire un don</a>
            <a href="/mur-de-priere">🙏 Déposer une prière</a>
            <a href="/connect">🌍 Rejoindre un groupe</a>
          </div>
        </aside>

        <!-- Formulaire -->
        <form class="ct-form" id="ctForm">
          <h3>Envoie-nous un message</h3>
          <input type="text" name="website" class="pw-hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="ct-row">
            <div class="pw-field"><label>Ton nom</label><input type="text" id="ctName" maxlength="80" placeholder="Prénom et nom" /></div>
            <div class="pw-field"><label>Ton e-mail *</label><input type="email" id="ctEmail" maxlength="120" placeholder="toi@exemple.com" required /></div>
          </div>
          <div class="pw-field">
            <label>Sujet</label>
            <select id="ctSubject">
              {subjects.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div class="pw-field">
            <label>Ton message *</label>
            <textarea id="ctMsg" maxlength="3000" rows="6" placeholder="Écris-nous ici…" required></textarea>
          </div>
          <label class="cn-consent"><input type="checkbox" id="ctConsent" /> <span>J'accepte que CMN utilise ces informations pour me répondre.</span></label>
          {turnstileKey && <div id="tsBox" style="margin:4px 0 12px"></div>}
          <button class="btn btn-gold" type="submit">Envoyer mon message</button>
          <span class="pw-msg" id="ctMsgOut"></span>
          <p class="pw-note">🔒 Tes informations restent confidentielles et ne servent qu'à te répondre.</p>
        </form>
      </div>
    </div>
  </section>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline define:vars={{ turnstileKey }}>
    (function () {
      window.__tsToken = '';
      // Anti-spam silencieux : on sonde l'arrivée de Turnstile et on le rend si possible.
      // Aucun message n'est jamais montré au visiteur ; les erreurs vont seulement dans la console.
      var tsBox = document.getElementById('tsBox');
      if (tsBox) {
        var tries = 0;
        var iv = setInterval(function () {
          tries++;
          if (window.turnstile && typeof window.turnstile.render === 'function') {
            clearInterval(iv);
            try {
              window.turnstile.render('#tsBox', {
                sitekey: turnstileKey,
                callback: function (t) { window.__tsToken = t; },
                'expired-callback': function () { window.__tsToken = ''; },
                'error-callback': function (code) { window.__tsToken = ''; console.warn('[Turnstile] erreur:', code); }
              });
            } catch (e) { console.warn('[Turnstile] render() a échoué:', e); }
          } else if (tries > 40) { // ~12s : le script Cloudflare ne s'est pas chargé
            clearInterval(iv);
            console.warn('[Turnstile] le script ne s\'est pas chargé (bloqueur/réseau ?).');
          }
        }, 300);
      }
      var form = document.getElementById('ctForm');
      var out = document.getElementById('ctMsgOut');
      var emailEl = document.getElementById('ctEmail');
      var msgEl = document.getElementById('ctMsg');

      // Pré-sélection du sujet depuis l'URL (ex: /contact?sujet=Proposer un groupe (Connect))
      try {
        var sujet = new URLSearchParams(window.location.search).get('sujet');
        if (sujet) {
          var sel = document.getElementById('ctSubject');
          var matched = false;
          for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].value === sujet) { sel.selectedIndex = i; matched = true; break; }
          }
          if (!matched) {
            for (var j = 0; j < sel.options.length; j++) { if (sel.options[j].value === 'Autre') { sel.selectedIndex = j; break; } }
          }
          if (sujet.indexOf('groupe') !== -1 && !msgEl.value) {
            msgEl.value = 'Bonjour, je souhaite proposer / animer un groupe CMN Connect.\n\nNom du groupe envisagé : \nPays ou thématique : \nQuelques mots sur le projet : ';
          }
          // amène l'utilisateur directement au formulaire
          setTimeout(function () { form.scrollIntoView({ behavior: 'smooth', block: 'center' }); document.getElementById('ctName').focus(); }, 150);
        }
      } catch (e) {}
      function tok() { return window.__tsToken || ''; }
      // Met un champ en surbrillance d'erreur (rouge) et affiche le message correspondant.
      function fieldError(el, text) {
        out.textContent = text;
        if (el) { el.classList.add('field-error'); el.focus(); }
      }
      function clearErrors() {
        emailEl.classList.remove('field-error');
        msgEl.classList.remove('field-error');
      }
      // Retire la surbrillance dès que l'utilisateur corrige le champ.
      emailEl.addEventListener('input', function () { emailEl.classList.remove('field-error'); });
      msgEl.addEventListener('input', function () { msgEl.classList.remove('field-error'); });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearErrors();
        var email = emailEl.value.trim();
        var message = msgEl.value.trim();
        if (email.indexOf('@') < 1) { fieldError(emailEl, 'Indique une adresse e-mail valide.'); return; }
        if (message.length < 10) { fieldError(msgEl, 'Écris quelques mots de plus (au moins 10 caractères).'); return; }
        if (!document.getElementById('ctConsent').checked) { out.textContent = 'Merci de cocher le consentement.'; return; }
        out.textContent = 'Envoi…';
        var body = {
          name: document.getElementById('ctName').value,
          email: email,
          subject: document.getElementById('ctSubject').value,
          message: message,
          website: form.website.value,
          turnstileToken: tok(),
        };
        fetch('/api/contact', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) {
            if (window.turnstile) { try { turnstile.reset(); window.__tsToken = ''; } catch (e) {} }
            if (res.ok) { out.textContent = 'Merci ! Ton message a bien été envoyé. Nous te répondrons bientôt 🙏'; form.reset(); }
            else {
              var msg = (res.d && res.d.error) || 'Une erreur est survenue.';
              // Si l'erreur concerne l'e-mail, on surligne le champ e-mail.
              if (/mail|domaine/i.test(msg)) fieldError(emailEl, msg);
              else if (/message|caract/i.test(msg)) fieldError(msgEl, msg);
              else out.textContent = msg;
            }
          })
          .catch(function () { out.textContent = 'Une erreur est survenue.'; });
      });
    })();
  </script>
</Layout>
