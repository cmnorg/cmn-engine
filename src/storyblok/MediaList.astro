---
import { renderRichText, storyblokEditable } from '@storyblok/astro';
import { sbImg } from '../img.js';
import { sbGet } from '../sb.js';
const { blok } = Astro.props;

function ytId(raw) {
  if (!raw) return '';
  const s = String(raw).trim();
  const m = s.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/|\/live\/)([\w-]{6,})/);
  if (m) return m[1];
  if (/^[\w-]{6,}$/.test(s)) return s;
  return '';
}
function assetUrl(a) {
  if (!a) return '';
  if (Array.isArray(a)) return assetUrl(a[0]);
  if (typeof a === 'string') return a;
  return a.filename || a.url || a.cached_url || '';
}

let vstories = [], rstories = [];
try {
  const [v, r] = await Promise.all([
    sbGet('cdn/stories', { version: 'draft', content_type: 'video', per_page: 100 }),
    sbGet('cdn/stories', { version: 'draft', content_type: 'report', per_page: 100 }),
  ]);
  vstories = v.data.stories || [];
  rstories = r.data.stories || [];
} catch (e) { vstories = []; rstories = []; }

const videos = vstories.map((s) => {
  const c = s.content || {};
  return {
    title: c.title || s.name,
    meta: c.info || c.year || '',
    yt: ytId(c.youtube_id || c.youtube_url || ''),
    file: assetUrl(c.video_file),
    thumb: assetUrl(c.thumbnail),
    theme: c.theme || '',
    desc: c.description ? (typeof c.description === 'string' ? c.description : renderRichText(c.description)) : '',
  };
});
const themes = [...new Set(videos.map((v) => v.theme).filter(Boolean))];
const reports = rstories.map((s) => {
  const c = s.content || {};
  return {
    title: c.title || s.name,
    country: c.country || '',
    date: c.date || '',
    pdf: assetUrl(c.pdf) || assetUrl(c.pdf_link),
    theme: c.theme || '',
    desc: c.description || '',
  };
});
const repThemes = [...new Set(reports.map((r) => r.theme).filter(Boolean))];

const introV = blok.intro_videos || blok.intro || '';
const introR = blok.intro_reports || blok.intro || '';
const L = {
  vids: blok.label_videos || 'Vidéos',
  reps: blok.label_reports || 'Rapport de la mission',
  back: blok.back_label || '← Retour aux médias',
  read: blok.read_label || 'Lire le rapport (PDF)',
  soon: blok.soon_label || 'Vidéo bientôt disponible.',
  pdfSoon: blok.pdf_soon_label || 'PDF à venir',
  emptyV: blok.empty_videos || 'Aucune vidéo pour le moment.',
  emptyR: blok.empty_reports || 'Aucun rapport pour le moment.',
  all: blok.all_label || 'Tous',
};
---
<section class="media-sec" {...storyblokEditable(blok)} data-media>
  <div class="wrap">
    {blok.label && <div class="phead-label disc-label">{blok.label}</div>}
    {blok.title && <h2 class="disc-h2">{blok.title}</h2>}
    <div class="media-main">
      <div class="ev-tabs" role="tablist">
        <button class="ev-tab active" type="button" data-mtab="videos">{L.vids}</button>
        <button class="ev-tab" type="button" data-mtab="reports">{L.reps}</button>
      </div>

      <div class="media-pane" data-pane="videos">
        {introV && <p class="sec-lead">{introV}</p>}
        {themes.length > 0 && (
          <div class="vid-filters" role="tablist">
            <button class="vid-filter active" type="button" data-theme="">{L.all}</button>
            {themes.map((t) => <button class="vid-filter" type="button" data-theme={t}>{t}</button>)}
          </div>
        )}
        <div class="media-grid">
          {videos.length === 0 && <p class="ev-empty">{L.emptyV}</p>}
          {videos.map((v) => (
            <article class="vid-card" data-yt={v.yt} data-file={v.file} data-title={v.title} data-meta={v.meta} data-theme={v.theme}>
              <div class="vid-ph" style={v.thumb ? `background-image:url(${sbImg(v.thumb, 800)})` : undefined}></div>
              <div class="bd">
                {v.theme && <span class="vid-theme">{v.theme}</span>}
                <h3>{v.title}</h3>
                {v.meta && <div class="vid-meta">{v.meta}</div>}
              </div>
              <template set:html={v.desc}></template>
            </article>
          ))}
        </div>
      </div>

      <div class="media-pane" data-pane="reports" hidden>
        {introR && <p class="sec-lead">{introR}</p>}
        {repThemes.length > 0 && (
          <div class="vid-filters" role="tablist">
            <button class="rep-filter active" type="button" data-theme="">{L.all}</button>
            {repThemes.map((t) => <button class="rep-filter" type="button" data-theme={t}>{t}</button>)}
          </div>
        )}
        <div class="media-grid media-reports">
          {reports.length === 0 && <p class="ev-empty">{L.emptyR}</p>}
          {reports.map((r) => (
            <div class="rep-card" data-theme={r.theme}>
              <div class="rep-row">
                {r.date && <div class="rep-date">{r.date}</div>}
                <div class="rep-info">
                  {r.theme && <span class="vid-theme">{r.theme}</span>}
                  <h3>{r.title}</h3>
                  {r.country && <div class="rep-country">{r.country}</div>}
                </div>
              </div>
              {r.desc && <p class="rep-desc">{r.desc}</p>}
              {r.pdf
                ? <a class="btn btn-ghost" href={r.pdf} target="_blank" rel="noopener">{L.read}</a>
                : <span class="rep-soon">{L.pdfSoon}</span>}
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="vid-detail" hidden>
      <button class="btn btn-ghost vid-back" type="button">{L.back}</button>
      <div class="video-embed"></div>
      <h2 class="vid-d-title"></h2>
      <div class="vid-d-meta"></div>
      <div class="vid-d-desc rich"></div>
    </div>
  </div>
</section>
<script define:vars={{ soon: L.soon }}>
  function initMedia() {
    document.querySelectorAll('[data-media]').forEach(function (root) {
      if (root.dataset.minit) return;
      root.dataset.minit = '1';
      var main = root.querySelector('.media-main');
      var detail = root.querySelector('.vid-detail');
      var tabs = root.querySelectorAll('.ev-tab');
      var panes = root.querySelectorAll('.media-pane');

      tabs.forEach(function (t) {
        t.addEventListener('click', function () {
          var which = t.getAttribute('data-mtab');
          tabs.forEach(function (x) { x.classList.remove('active'); });
          t.classList.add('active');
          panes.forEach(function (p) { p.hidden = p.getAttribute('data-pane') !== which; });
        });
      });

      function openVideo(card) {
        var yt = card.getAttribute('data-yt');
        var file = card.getAttribute('data-file');
        var embed = detail.querySelector('.video-embed');
        if (yt) {
          embed.innerHTML = '<iframe src="https://www.youtube.com/embed/' + yt + '?rel=0" title="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>';
        } else if (file) {
          embed.innerHTML = '<video src="' + file + '" controls autoplay playsinline style="position:absolute;inset:0;width:100%;height:100%;background:#000"></video>';
        } else {
          embed.innerHTML = '<div class="video-soon">' + soon + '</div>';
        }
        detail.querySelector('.vid-d-title').textContent = card.getAttribute('data-title') || '';
        detail.querySelector('.vid-d-meta').textContent = card.getAttribute('data-meta') || '';
        var tpl = card.querySelector('template');
        detail.querySelector('.vid-d-desc').innerHTML = tpl ? tpl.innerHTML : '';
        main.hidden = true;
        detail.hidden = false;
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      root.querySelectorAll('.vid-card').forEach(function (card) {
        card.addEventListener('click', function () { openVideo(card); });
      });

      function bindFilters(filterSel, cardSel) {
        var filters = root.querySelectorAll(filterSel);
        var cards = root.querySelectorAll(cardSel);
        filters.forEach(function (f) {
          f.addEventListener('click', function () {
            var th = f.getAttribute('data-theme');
            filters.forEach(function (x) { x.classList.remove('active'); });
            f.classList.add('active');
            cards.forEach(function (c) {
              c.hidden = !!th && c.getAttribute('data-theme') !== th;
            });
          });
        });
      }
      bindFilters('.vid-filter', '.vid-card');
      bindFilters('.rep-filter', '.rep-card');
      detail.querySelector('.vid-back').addEventListener('click', function () {
        detail.querySelector('.video-embed').innerHTML = '';
        detail.hidden = true;
        main.hidden = false;
      });
    });
  }
  initMedia();
  document.addEventListener('astro:page-load', initMedia);
</script>
