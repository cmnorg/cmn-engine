---
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import { storyblokEditable } from '@storyblok/astro';
const { blok } = Astro.props;
---
<section class="leaders-sec" {...storyblokEditable(blok)} data-leaders>
  <div class="wrap">
    {blok.title && <h2 class="sec-title">{blok.title}</h2>}
    {blok.subtitle && <p class="sec-lead">{blok.subtitle}</p>}
    <div class="leaders-grid">
      {blok.items?.map((c) => <StoryblokComponent blok={c} />)}
    </div>
    {blok.note && <p class="leaders-note">{blok.note}</p>}
  </div>
  <div class="lead-modal" hidden>
    <div class="lead-modal-backdrop" data-close></div>
    <div class="lead-modal-card" role="dialog" aria-modal="true">
      <button class="lead-modal-x" type="button" data-close aria-label="Fermer">×</button>
      <div class="lead-modal-hero">
        <div class="lead-modal-ph"></div>
        <div>
          <span class="lead-modal-role"></span>
          <h2 class="lead-modal-name"></h2>
        </div>
      </div>
      <p class="lead-modal-bio"></p>
    </div>
  </div>
</section>
<script>
  function initLeaders() {
    document.querySelectorAll('[data-leaders]').forEach(function (root) {
      if (root.dataset.linit) return;
      root.dataset.linit = '1';
      var modal = root.querySelector('.lead-modal');
      if (!modal) return;
      var ph = modal.querySelector('.lead-modal-ph');
      var roleEl = modal.querySelector('.lead-modal-role');
      var nameEl = modal.querySelector('.lead-modal-name');
      var bioEl = modal.querySelector('.lead-modal-bio');
      function open(card) {
        var photo = card.getAttribute('data-photo');
        ph.style.backgroundImage = photo ? ('url(' + photo + ')') : '';
        roleEl.textContent = card.getAttribute('data-role') || '';
        nameEl.textContent = card.getAttribute('data-name') || '';
        var bio = card.querySelector('.lead-bio');
        bioEl.textContent = bio ? bio.textContent : '';
        modal.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function close() {
        modal.hidden = true;
        document.body.style.overflow = '';
      }
      root.querySelectorAll('.lead-card').forEach(function (card) {
        card.addEventListener('click', function () { open(card); });
      });
      modal.querySelectorAll('[data-close]').forEach(function (el) {
        el.addEventListener('click', close);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !modal.hidden) close();
      });
    });
  }
  initLeaders();
  document.addEventListener('astro:page-load', initLeaders);
</script>
