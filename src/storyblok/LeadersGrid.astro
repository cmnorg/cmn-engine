---
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import { storyblokEditable } from '@storyblok/astro';
const { blok } = Astro.props;
const backLabel = blok.back_label || '← Retour à la gouvernance';
const verseText = blok.verse_text || '« Allez, faites de toutes les nations des disciples. »';
const verseRef = blok.verse_ref || 'Matthieu 28:19';
const contactLabel = blok.contact_label || 'Contacter le bureau';
const contactLink = blok.contact_link?.url || blok.contact_link?.cached_url || '/contact';
---
<section class="leaders-sec" {...storyblokEditable(blok)} data-leaders>
  <div class="wrap">
    <div class="leaders-list">
      {blok.title && <h2 class="sec-title">{blok.title}</h2>}
      {blok.subtitle && <p class="sec-lead">{blok.subtitle}</p>}
      <div class="leaders-grid">
        {blok.items?.map((c) => <StoryblokComponent blok={c} />)}
      </div>
      {blok.note && <p class="leaders-note">{blok.note}</p>}
    </div>
    <div class="leader-detail" hidden>
      <button class="btn btn-ghost leader-back" type="button">{backLabel}</button>
      <div class="leader-hero">
        <div class="leader-detail-ph"></div>
        <div>
          <span class="leader-detail-role"></span>
          <h2 class="leader-detail-name"></h2>
        </div>
      </div>
      <p class="leader-detail-bio"></p>
      <blockquote class="verse leader-detail-verse">{verseText} <cite>— {verseRef}</cite></blockquote>
      <a class="btn btn-gold leader-detail-contact" href={contactLink}>{contactLabel}</a>
    </div>
  </div>
</section>
<script>
  function initLeaders() {
    document.querySelectorAll('[data-leaders]').forEach(function (root) {
      if (root.dataset.linit) return;
      root.dataset.linit = '1';
      var list = root.querySelector('.leaders-list');
      var detail = root.querySelector('.leader-detail');
      if (!list || !detail) return;
      var pane = root.closest('.disc-pane');
      var ph = detail.querySelector('.leader-detail-ph');
      var roleEl = detail.querySelector('.leader-detail-role');
      var nameEl = detail.querySelector('.leader-detail-name');
      var bioEl = detail.querySelector('.leader-detail-bio');
      function siblings() {
        if (!pane) return [];
        return Array.prototype.filter.call(pane.children, function (ch) { return ch !== root; });
      }
      function open(card) {
        var photo = card.getAttribute('data-photo');
        ph.style.backgroundImage = photo ? ('url(' + photo + ')') : '';
        roleEl.textContent = card.getAttribute('data-role') || '';
        nameEl.textContent = card.getAttribute('data-name') || '';
        var bio = card.querySelector('.lead-bio');
        bioEl.textContent = bio ? bio.textContent : '';
        siblings().forEach(function (s) { s.hidden = true; });
        list.hidden = true;
        detail.hidden = false;
        (pane || root).scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      function back() {
        detail.hidden = true;
        list.hidden = false;
        siblings().forEach(function (s) { s.hidden = false; });
      }
      root.querySelectorAll('.lead-card').forEach(function (card) {
        card.addEventListener('click', function () { open(card); });
      });
      detail.querySelector('.leader-back').addEventListener('click', back);
    });
  }
  initLeaders();
  document.addEventListener('astro:page-load', initLeaders);
</script>
