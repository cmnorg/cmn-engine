---
import { storyblokEditable, renderRichText } from '@storyblok/astro';
const { blok } = Astro.props;
const html = blok.body ? renderRichText(blok.body) : '';
const lead = blok.lead ? ' txt-lead' : '';
---
<section class={`txt${lead}`} {...storyblokEditable(blok)}>
  <div class="wrap">
    {blok.title && <h2 class="sec-title">{blok.title}</h2>}
    <div class="rich" set:html={html}></div>
  </div>
</section>
