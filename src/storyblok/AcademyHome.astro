---
import { useStoryblokApi, storyblokEditable } from '@storyblok/astro';
import { sbImg } from '../img.js';
const { blok } = Astro.props;

function assetUrl(a) {
  if (!a) return '';
  if (Array.isArray(a)) return assetUrl(a[0]);
  if (typeof a === 'string') return a;
  return a.filename || a.url || a.cached_url || '';
}

let trackStories = [], courseStories = [];
try {
  const api = useStoryblokApi();
  const [t, c] = await Promise.all([
    api.get('cdn/stories', { version: 'draft', content_type: 'track', per_page: 100 }),
    api.get('cdn/stories', { version: 'draft', content_type: 'course', per_page: 100 }),
  ]);
  trackStories = t.data.stories || [];
  courseStories = c.data.stories || [];
} catch (e) { trackStories = []; courseStories = []; }

const trackCourses = {};
courseStories.forEach((s) => {
  const k = (s.content || {}).track;
  if (k) (trackCourses[k] = trackCourses[k] || []).push(s.full_slug);
});

const tracks = trackStories.map((s) => {
  const c = s.content || {};
  const key = c.key || s.slug;
  return {
    key,
    title: c.title || s.name,
    subtitle: c.subtitle || '',
    icon: c.icon || '',
    illustration: assetUrl(c.illustration),
    level: c.level || '',
    duration: c.duration || '',
    cta: c.cta_label || 'Commencer',
    url: '/' + s.full_slug,
    count: (trackCourses[key] || []).length,
    advice: c.advice || '',
    order: Number(c.order) || ({ 'decouvrir': 1, 'premiers-pas': 2, 'disciple': 3, 'faire-disciples': 4, 'leadership': 5 }[key]) || 999,
  };
}).sort((a, b) => a.order - b.order);

const recoMap = {};
tracks.forEach((t) => { recoMap[t.key] = { title: t.title, url: t.url, icon: t.icon }; });

// Questionnaire d'orientation. stage 0..4 -> parcours.
// La 1re question sert de "socle" : si stage < 2, on recommande ce niveau quoi qu'il arrive.
const stageKeys = ['decouvrir', 'premiers-pas', 'disciple', 'faire-disciples', 'leadership'];
const defaultQuestions = [
  {
    q: 'Où en es-tu avec Jésus ?',
    options: [
      { t: 'Je ne le connais pas encore / je découvre', s: 0 },
      { t: 'Je viens de donner ma vie à Christ', s: 1 },
      { t: 'Je suis chrétien depuis un moment', s: 2 },
    ],
  },
  {
    q: 'Quel est ton engagement aujourd’hui ?',
    options: [
      { t: 'Je débute, je cherche des bases', s: 1 },
      { t: 'Je sers dans une église', s: 2 },
      { t: 'Je suis responsable, pasteur ou missionnaire', s: 4 },
    ],
  },
  {
    q: 'Qu’aimerais-tu vivre en priorité ?',
    options: [
      { t: 'Mieux connaître Jésus et grandir', s: 2 },
      { t: 'Annoncer l’Évangile autour de moi', s: 3 },
      { t: 'Diriger, former ou partir en mission', s: 4 },
    ],
  },
];
const cmsQuestions = (blok.orientation || []).map((q) => ({
  q: q.question || '',
  options: (q.options || []).map((o) => ({ t: o.label || '', s: Number(o.stage) || 0 })),
})).filter((q) => q.q && q.options.length);
const questions = cmsQuestions.length ? cmsQuestions : defaultQuestions;
---
<section class="acad" {...storyblokEditable(blok)} data-academy>
  <div class="wrap">
    {blok.label && <div class="phead-label disc-label">{blok.label}</div>}
    {blok.title && <h2 class="disc-h2">{blok.title}</h2>}
    {blok.intro && <p class="sec-lead">{blok.intro}</p>}

    {tracks.length > 0 && (
      <div class="quiz-card" data-quiz>
        <div class="quiz-head">
          <span class="quiz-emoji">🧭</span>
          <div>
            <h3>{blok.quiz_title || 'Trouve ton parcours'}</h3>
            <p>{blok.quiz_sub || 'Réponds à 3 questions, on te recommande par où commencer.'}</p>
          </div>
        </div>
        <div class="quiz-body">
          {questions.map((qq, qi) => (
            <div class="quiz-q" data-q={qi} hidden={qi > 0 ? true : undefined}>
              <div class="quiz-q-label">{qi + 1}. {qq.q}</div>
              <div class="quiz-opts">
                {qq.options.map((o) => (
                  <button class="quiz-opt" type="button" data-stage={o.s}>{o.t}</button>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div class="quiz-result" hidden>
          <div class="quiz-result-inner"></div>
        </div>
      </div>
    )}

    <div class="track-grid">
      {tracks.length === 0 && <p class="ev-empty">Aucun parcours pour le moment.</p>}
      {tracks.map((t, i) => (
        <a class={`track-card accent-${i % 5}`} href={t.url} data-track={t.key} data-count={t.count}>
          <div class="track-illus" style={t.illustration ? `background-image:url(${sbImg(t.illustration, 800)})` : undefined}></div>
          <div class="track-body">
            <span class="track-icon">{t.icon}</span>
            <span class="track-reco-badge" hidden>✨ Recommandé pour toi</span>
            <h3>{t.title}</h3>
            {t.subtitle && <p>{t.subtitle}</p>}
            <div class="track-meta">
              <span>{t.count} cours</span>
              {t.level && <span>· {t.level}</span>}
              {t.duration && <span>· {t.duration}</span>}
            </div>
            {t.advice && <div class="track-advice">{t.advice}</div>}
            <div class="track-prog" data-track-prog hidden><div class="track-prog-bar"><i></i></div><span class="track-prog-txt"></span></div>
            <span class="btn btn-gold track-cta">{t.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
<script define:vars={{ recoMap, stageKeys, trackCourses }}>
  function readDone() {
    try { return JSON.parse(localStorage.getItem('cmn_academy_done') || '{}'); } catch (e) { return {}; }
  }
  function initAcademy() {
    document.querySelectorAll('[data-academy]').forEach(function (root) {
      if (root.dataset.ainit) return; root.dataset.ainit = '1';
      // progression par parcours
      var done = readDone();
      root.querySelectorAll('.track-card').forEach(function (card) {
        var key = card.getAttribute('data-track');
        var slugs = trackCourses[key] || [];
        if (!slugs.length) return;
        var d = slugs.filter(function (s) { return done[s]; }).length;
        if (d > 0) {
          var box = card.querySelector('[data-track-prog]');
          box.hidden = false;
          box.querySelector('i').style.width = Math.round((d / slugs.length) * 100) + '%';
          box.querySelector('.track-prog-txt').textContent = d + '/' + slugs.length + ' terminés';
        }
      });
      // quiz d'orientation (adaptatif)
      var quiz = root.querySelector('[data-quiz]');
      if (!quiz) return;
      var result = quiz.querySelector('.quiz-result');
      var inner = quiz.querySelector('.quiz-result-inner');
      var allQs = Array.prototype.slice.call(quiz.querySelectorAll('.quiz-q'));
      var firstQ = allQs[0];
      var laterQs = allQs.slice(1);

      function firstStage() {
        if (!firstQ) return null;
        var sel = firstQ.querySelector('.quiz-opt.on');
        return sel ? (parseInt(sel.getAttribute('data-stage'), 10) || 0) : null;
      }
      function setLaterVisible(v) { laterQs.forEach(function (q) { q.hidden = !v; }); }
      function messageFor(stage) {
        if (stage === 0) return 'Bienvenue ! C’est une belle décision de vouloir découvrir Jésus. Voici par où commencer :';
        if (stage === 1) return 'Félicitations pour ce nouveau départ avec Dieu ! Voici les fondations pour bien grandir :';
        return 'Voici le parcours qui correspond à là où tu en es aujourd’hui :';
      }
      function showReco(stage) {
        var key = stageKeys[stage] || stageKeys[0];
        var reco = recoMap[key] || Object.values(recoMap)[0];
        if (!reco) return;
        inner.innerHTML = '<div class="quiz-reco-msg">' + messageFor(stage) + '</div>'
          + '<div class="quiz-reco-label">Parcours recommandé</div>'
          + '<div class="quiz-reco-title">' + (reco.icon || '') + ' ' + reco.title + '</div>'
          + '<a class="btn btn-gold" href="' + reco.url + '">Commencer ce parcours</a>';
        result.hidden = false;
        // mettre en avant la carte du parcours recommandé
        root.querySelectorAll('.track-card').forEach(function (c) {
          c.classList.remove('is-reco');
          var b = c.querySelector('.track-reco-badge'); if (b) b.hidden = true;
        });
        var card = root.querySelector('.track-card[data-track="' + key + '"]');
        if (card) {
          card.classList.add('is-reco');
          var badge = card.querySelector('.track-reco-badge'); if (badge) badge.hidden = false;
          card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
      function update() {
        var base = firstStage();
        if (base === null) { setLaterVisible(false); result.hidden = true; return; }
        if (base < 2) { setLaterVisible(false); showReco(base); return; }
        setLaterVisible(true);
        var stages = [base], complete = true;
        laterQs.forEach(function (q) {
          var sel = q.querySelector('.quiz-opt.on');
          if (sel) stages.push(parseInt(sel.getAttribute('data-stage'), 10) || 0);
          else complete = false;
        });
        if (!complete) { result.hidden = true; return; }
        showReco(Math.max.apply(null, stages));
      }
      allQs.forEach(function (q) {
        q.querySelectorAll('.quiz-opt').forEach(function (opt) {
          opt.addEventListener('click', function () {
            q.querySelectorAll('.quiz-opt').forEach(function (x) { x.classList.remove('on'); });
            opt.classList.add('on');
            update();
          });
        });
      });
      setLaterVisible(false);
    });
  }
  initAcademy();
  document.addEventListener('astro:page-load', initAcademy);
</script>
