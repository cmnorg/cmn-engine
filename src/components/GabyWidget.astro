---
import { localeFromPath, localizedHref } from '../i18n.js';
const locale = localeFromPath(Astro.url.pathname);
const tipText = { fr:'Gaby · Besoin d’aide ?', en:'Gaby · Need help?', es:'Gaby · ¿Necesitas ayuda?', id:'Gaby · Butuh bantuan?', zh:'Gaby · 需要帮助吗？' }[locale] || 'Gaby · Besoin d’aide ?';
// Liens localisés (pages CMS préfixées ; pages autonomes à la racine)
const href = {
  don: localizedHref('faire-un-don', locale),
  partners: localizedHref('partenaires', locale),
  prayer: localizedHref('mur-de-priere', locale),
  connect: localizedHref('connect', locale),
  contact: localizedHref('contact', locale),
  events: localizedHref('actualites', locale),
  academy: localizedHref('academy', locale),
};
---
<div class="gaby" data-locale={locale}>
  <div class="gaby-tip" id="gabyTip"><span>{tipText}</span><button class="gaby-tip-x" id="gabyTipX" aria-label="Fermer">✕</button></div>
  <button class="gaby-launch pulse" id="gabyLaunch" aria-label="Gabriel — assistant CMN">
    <span class="gaby-ava">🕊️</span>
  </button>

  <div class="gaby-panel" id="gabyPanel" hidden>
    <div class="gaby-head">
      <span class="gaby-ava sm">🕊️</span>
      <div class="gaby-head-t"><strong>Gabriel</strong><span id="gabySub"></span></div>
      <button class="gaby-ico" id="gabyVoice" aria-label="Lecture vocale" title="Lecture vocale">🔈</button>
      <button class="gaby-ico" id="gabyClose" aria-label="Fermer">✕</button>
    </div>
    <div class="gaby-msgs" id="gabyMsgs" aria-live="polite"></div>
    <div class="gaby-chips" id="gabyChips"></div>
    <form class="gaby-form" id="gabyForm">
      <input type="text" id="gabyInput" autocomplete="off" />
      <button type="submit" class="gaby-send" aria-label="Envoyer">➤</button>
    </form>
    <p class="gaby-disc" id="gabyDisc"></p>
  </div>
</div>

