---
import { localeFromPath, barePath, localizedHref, t } from '../i18n.js';
const { settings } = Astro.props;
const logoF = settings?.logo_footer?.filename;
const logoFH = Number(settings?.logo_footer_height) > 0 ? Number(settings.logo_footer_height) : 50;
const menu = Array.isArray(settings?.menu) ? settings.menu : [];
function slugify(s){ return String(s).normalize('NFD').replace(/[̀-ͯ]/g,'').toLowerCase().replace(/[^a-z0-9/]+/g,'-').replace(/\/+/g,'/').replace(/-+/g,'-').replace(/^[-/]+|-+$/g,''); }
function hrefOf(l){ if(!l) return '#'; var raw=String(l.url||l.cached_url||''); if(!raw) return '#'; if(/^https?:/i.test(raw)||raw.charAt(0)==='#'||/^mailto:|^tel:/i.test(raw)) return raw; return '/'+slugify(raw); }
const locale = localeFromPath(Astro.url.pathname);
function menuHref(l){ const h = hrefOf(l); if(/^https?:/i.test(h)||h.charAt(0)==='#'||/^mailto:|^tel:/i.test(h)) return h; return localizedHref(h.replace(/^\/+/,'').replace(/\/+$/,''), locale); }
function u(v){ if(!v) return ''; if(typeof v==='string') return v; return v.url || v.cached_url || ''; }
const yt=u(settings?.youtube), fb=u(settings?.facebook), ig=u(settings?.instagram), tk=u(settings?.tiktok), li=u(settings?.linkedin), wa=u(settings?.whatsapp_channel);
---
<footer class="ft">
  <div class="wrap ft-row">
    <div class="ft-left">
      {logoF ? <img class="ft-logo" src={logoF} alt="CMN" style={`height:${logoFH}px`} /> : <strong class="ft-wm">Christians <span class="g">on Mission</span> for Nations</strong>}
      <p class="ft-tag">{t(locale, "Agir pour transformer, inspirer l'espoir.")}</p>
      <nav class="ft-nav">
        {menu.map((m) => <a href={menuHref(m.link)}>{t(locale, m.label)}</a>)}
      </nav>
      <div class="ft-soc">
    {yt && <a href={yt} target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6z"/></svg></a>}
    {fb && <a href={fb} target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12a12 12 0 1 0-13.9 11.9v-8.4H7v-3.5h3.1V9.4c0-3 1.8-4.7 4.6-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9v2.2h3.4l-.5 3.5h-2.9v8.4A12 12 0 0 0 24 12z"/></svg></a>}
    {ig && <a href={ig} target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.1.4.3 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.1-1 .3-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.1-.4-.3-1-.4-2.2-.1-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.1 1-.3 2.2-.4 1.3-.1 1.7-.1 4.9-.1zM12 0C8.7 0 8.3 0 7 .1 5.7.1 4.8.3 4.1.6c-.8.3-1.4.7-2.1 1.4C1.3 2.7.9 3.3.6 4.1.3 4.8.1 5.7.1 7 0 8.3 0 8.7 0 12s0 3.7.1 5c0 1.3.2 2.2.5 2.9.3.8.7 1.4 1.4 2.1.7.7 1.3 1.1 2.1 1.4.7.3 1.6.5 2.9.5 1.3.1 1.7.1 5 .1s3.7 0 5-.1c1.3 0 2.2-.2 2.9-.5.8-.3 1.4-.7 2.1-1.4.7-.7 1.1-1.3 1.4-2.1.3-.7.5-1.6.5-2.9.1-1.3.1-1.7.1-5s0-3.7-.1-5c0-1.3-.2-2.2-.5-2.9-.3-.8-.7-1.4-1.4-2.1-.7-.7-1.3-1.1-2.1-1.4-.7-.3-1.6-.5-2.9-.5C15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-10.4a1.4 1.4 0 1 1-2.9 0 1.4 1.4 0 0 1 2.9 0z"/></svg></a>}
    {tk && <a href={tk} target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16.6 5.8a4.3 4.3 0 0 1-1-2.8h-3.3v13.2a2.6 2.6 0 1 1-2.6-2.6c.3 0 .5 0 .8.1V10.3a6 6 0 0 0-.8-.1 5.9 5.9 0 1 0 5.9 5.9V9.4a7.5 7.5 0 0 0 4.4 1.4V7.5a4.3 4.3 0 0 1-3.4-1.7z"/></svg></a>}
    {li && <a href={li} target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5V8h3v11zM6.5 6.7a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6zM19 19h-3v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V19h-3V8h2.9v1.5h.04A3.2 3.2 0 0 1 14 8c3 0 3.6 2 3.6 4.6V19z"/></svg></a>}
    {wa && <a href={wa} target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.56 14.13c-.25.7-1.44 1.3-1.99 1.35-.55.05-1.06.25-3.57-.74-3.02-1.19-4.95-4.27-5.1-4.47-.15-.2-1.22-1.62-1.22-3.09s.77-2.19 1.04-2.49c.27-.3.59-.37.79-.37.2 0 .39 0 .56.01.18.01.42-.07.66.5.25.6.84 2.07.91 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.17-.31.38-.45.51-.15.15-.3.31-.13.61.17.3.76 1.25 1.63 2.02 1.12 1 2.07 1.31 2.37 1.46.3.15.47.12.65-.07.18-.2.74-.86.94-1.16.2-.3.4-.25.66-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.72-.18 1.42z"/></svg></a>}
      </div>
    </div>
    <div class="ft-right">
      <div class="ft-langs">FR · EN · ES · PT · 中文</div>
      <small>{t(locale, '© CMN — Tous droits réservés.')}</small>
    </div>
  </div>
  <div class="wrap ft-legal"><a href="#">{t(locale, 'Confidentialité')}</a> · <a href="#">{t(locale, 'Mentions légales')}</a> · <a href="#">{t(locale, 'Gérer mes cookies')}</a></div>
</footer>
