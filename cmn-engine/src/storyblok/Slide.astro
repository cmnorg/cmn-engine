---
import { storyblokEditable } from '@storyblok/astro';
const { blok } = Astro.props;
const img = blok.image?.filename;
const vid = blok.video?.filename;
function ytId(raw) {
  if (!raw) return '';
  const s = String(raw).trim();
  const m = s.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/|\/live\/)([\w-]{6,})/);
  if (m) return m[1];
  if (/^[\w-]{6,}$/.test(s)) return s;
  return '';
}
const yt = ytId(blok.youtube_id || blok.youtube_url || '');
const ytSrc = yt
  ? `https://www.youtube.com/embed/${yt}?autoplay=1&mute=1&loop=1&playlist=${yt}&controls=0&showinfo=0&modestbranding=1&rel=0&playsinline=1&enablejsapi=1`
  : '';
---
<div class="slide" {...storyblokEditable(blok)}>
  {yt
    ? <div class="slide-yt"><iframe src={ytSrc} title={blok.title || 'Vidéo'} frameborder="0" allow="autoplay; encrypted-media; picture-in-picture" allowfullscreen></iframe></div>
    : vid
      ? <video src={vid} autoplay muted loop playsinline preload="metadata" poster={img || undefined}></video>
      : img && <img src={img} alt={blok.image?.alt || ''} />}
  <div class="slide-cap">
    {blok.title && <h2>{blok.title}</h2>}
    {blok.text && <p>{blok.text}</p>}
    {blok.button_label && <a class="btn btn-gold">{blok.button_label}</a>}
  </div>
</div>
